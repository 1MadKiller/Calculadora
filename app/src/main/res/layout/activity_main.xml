<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:id="@+id/layout_welcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bem-vindo a calculadora mais bonita do mundo"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="40dp"
            android:fontFamily="@font/douglas_font"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_entrar"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="ENTRAR"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="30dp"
            app:backgroundTint="#4CAF50"/>

        <TextView
            android:id="@+id/tv_assinatura_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by DouglasDev"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginTop="100dp"
            android:fontFamily="@font/douglas_font"
            android:shadowColor="#4CAF50"
            android:shadowRadius="15"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_main_app"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/top_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="15dp">

            <TextView
                android:id="@+id/nav_calculadora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculadora"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:alpha="1.0"/>

            <View
                android:layout_width="30dp"
                android:layout_height="match_parent"/>

            <TextView
                android:id="@+id/nav_conversor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conversor"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:alpha="0.4"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_calculator_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cores:" android:textColor="#FFFFFF" android:textSize="14sp" />
                <Button android:id="@+id/btn_red" android:layout_width="32dp" android:layout_height="32dp" android:backgroundTint="#FF5252" android:layout_margin="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                <Button android:id="@+id/btn_blue" android:layout_width="32dp" android:layout_height="32dp" android:backgroundTint="#448AFF" android:layout_margin="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                <Button android:id="@+id/btn_green" android:layout_width="32dp" android:layout_height="32dp" android:backgroundTint="#4CAF50" android:layout_margin="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                <Button android:id="@+id/btn_pink" android:layout_width="32dp" android:layout_height="32dp" android:backgroundTint="#FF4081" android:layout_margin="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                <Button android:id="@+id/btn_dark" android:layout_width="32dp" android:layout_height="32dp" android:backgroundTint="#050505" android:layout_margin="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                <Button android:id="@+id/btn_white" android:layout_width="32dp" android:layout_height="32dp" android:backgroundTint="#FAFAFA" android:layout_margin="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_toggle_history" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Histórico" android:textColor="#4CAF50" android:textSize="12sp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:id="@+id/card_display" android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginTop="8dp" app:cardBackgroundColor="#1E1E1E" app:cardCornerRadius="16dp">
                <TextView android:id="@+id/tv_display" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical|end" android:padding="20dp" android:text="0" android:textColor="#FFFFFF" android:textSize="40sp" android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/card_history" android:layout_width="match_parent" android:layout_height="110dp" android:layout_marginTop="8dp" android:visibility="gone" app:cardBackgroundColor="#1E1E1E" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Histórico Recente" android:textColor="#888888" android:textSize="12sp" />
                        <TextView android:id="@+id/btn_clear_history" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Apagar" android:textColor="#F44336" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"><TextView android:id="@+id/tv_history_content" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#CCCCCC" android:textSize="14sp" /></ScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <GridLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:columnCount="4" android:layout_marginTop="10dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_c" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="C" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#F44336"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_backspace" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="⌫" android:textColor="#FFFFFF" android:textSize="20sp" app:cornerRadius="15dp" app:backgroundTint="#333333"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_div_op" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="÷" android:textColor="#FFFFFF" android:textSize="24sp" app:cornerRadius="15dp" app:backgroundTint="#4CAF50"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_mult_op" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="×" android:textColor="#FFFFFF" android:textSize="24sp" app:cornerRadius="15dp" app:backgroundTint="#4CAF50"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_7" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="7" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_8" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="8" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_9" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="9" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_sub_op" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="-" android:textColor="#FFFFFF" android:textSize="24sp" app:cornerRadius="15dp" app:backgroundTint="#4CAF50"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_4" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="4" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_5" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="5" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_6" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="6" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_soma_op" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="+" android:textColor="#FFFFFF" android:textSize="24sp" app:cornerRadius="15dp" app:backgroundTint="#4CAF50"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_1" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="1" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_2" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="2" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_3" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="3" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_igual" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="=" android:textColor="#FFFFFF" android:textSize="28sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#4CAF50"/>
                <View android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_0" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="0" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_dot" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="." android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
            </GridLayout>

            <TextView android:id="@+id/tv_assinatura" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="25dp" android:gravity="center" android:text="DouglasDev" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold" android:fontFamily="@font/douglas_font" android:shadowColor="#4CAF50" android:shadowRadius="15" android:layout_marginBottom="180dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_conversor_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ScrollView 
                android:id="@+id/layout_conversor_scroll" 
                android:layout_width="match_parent" 
                android:layout_height="0dp" 
                android:layout_weight="1" 
                android:padding="20dp">

                <LinearLayout 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:orientation="vertical">

                    <GridLayout 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:columnCount="3">

                        <LinearLayout 
                            android:id="@+id/item_moeda" 
                            android:layout_width="0dp" 
                            android:layout_height="110dp" 
                            android:layout_columnWeight="1" 
                            android:orientation="vertical" 
                            android:gravity="center" 
                            android:clickable="true" 
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💵" android:textSize="30sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Moeda" android:textColor="#FFFFFF" android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout 
                            android:id="@+id/item_imc" 
                            android:layout_width="0dp" 
                            android:layout_height="110dp" 
                            android:layout_columnWeight="1" 
                            android:orientation="vertical" 
                            android:gravity="center" 
                            android:clickable="true" 
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤸" android:textSize="30sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IMC" android:textColor="#FFFFFF" android:textSize="13sp"/>
                        </LinearLayout>

                    </GridLayout>

                    <TextView 
                        android:id="@+id/tv_assinatura_conv" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:layout_marginTop="40dp" 
                        android:gravity="center" 
                        android:text="DouglasDev" 
                        android:textColor="#FFFFFF" 
                        android:textSize="32sp" 
                        android:textStyle="bold" 
                        android:fontFamily="@font/douglas_font" 
                        android:shadowColor="#4CAF50" 
                        android:shadowRadius="15" 
                        android:layout_marginBottom="20dp" />

                    <!-- Links do rodapé na tela Conversor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="By:DouglasDev"
                            android:textColor="#AAAAAA"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"/>


                        <TextView
                            android:id="@+id/tv_telegram_link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Telegram"
                            android:textColor="#229ED9"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:padding="10dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_moeda_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical"><ImageButton android:id="@+id/btn_moeda_back" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_revert" android:tint="#FFFFFF"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Moeda" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginStart="16dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:id="@+id/row_brl" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="10dp" android:background="#1E1E1E"><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Real Brasileiro" android:textColor="#FFFFFF" android:textSize="16sp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BRL" android:textColor="#888888" android:textSize="12sp"/></LinearLayout><TextView android:id="@+id/tv_moeda_brl" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp"/></LinearLayout>
                <LinearLayout android:id="@+id/row_usd" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="10dp" android:layout_marginTop="8dp"><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dólar Americano" android:textColor="#FFFFFF" android:textSize="16sp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="USD" android:textColor="#888888" android:textSize="12sp"/></LinearLayout><TextView android:id="@+id/tv_moeda_usd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp"/></LinearLayout>
                <LinearLayout android:id="@+id/row_eur" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="10dp" android:layout_marginTop="8dp"><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Euro" android:textColor="#FFFFFF" android:textSize="16sp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EUR" android:textColor="#888888" android:textSize="12sp"/></LinearLayout><TextView android:id="@+id/tv_moeda_eur" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp"/></LinearLayout>
                <TextView android:id="@+id/tv_moeda_info" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center" android:textColor="#666666" android:textSize="12sp" android:text="Taxas atualizadas agora via AwesomeAPI"/>
            </LinearLayout>
            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="4" android:padding="8dp" android:background="#121212">
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_mc" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="C" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#F44336"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_mback" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="⌫" android:textColor="#FFFFFF" android:textSize="18sp" app:cornerRadius="15dp" app:backgroundTint="#333333"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_mdiv" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="÷" android:textColor="#FFFFFF" android:textSize="22sp" app:cornerRadius="15dp" app:backgroundTint="#FF9800"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_mmult" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="×" android:textColor="#FFFFFF" android:textSize="22sp" app:cornerRadius="15dp" app:backgroundTint="#FF9800"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_m7" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="7" android:textColor="#FFFFFF" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_m8" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="8" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_m9" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="9" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_msub" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="-" android:textColor="#FFFFFF" android:textSize="22sp" app:cornerRadius="15dp" app:backgroundTint="#FF9800"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/mbtn_m4" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="4dp" android:text="4" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="15dp" app:backgroundTint="#2C2C2C"/>
